# Copy to .env and edit as needed
# Optional: Docker Compose project/container prefix.
COMPOSE_PROJECT_NAME=exchangehub

# Path on host to WordPress uploads (will be mounted into container)
UPLOADS_HOST_PATH=./wp-content/uploads

# Your OpenExchangeRates App ID
#OPENEXCHANGE_APP_ID=YOUR_APP_ID

# Optional: rotate multiple OpenExchangeRates App IDs, comma-separated.
# At 5-minute intervals this uses about 8,640 requests/month total.
#OPENEXCHANGE_APP_IDS=APP_ID_1,APP_ID_2,APP_ID_3

# Optional: route only the fetcher outbound API requests through a proxy/NAT.
# This hides the web server's direct outbound IP from the rate provider.
#FETCHER_HTTP_PROXY=http://user:pass@proxy-host:proxy-port
#FETCHER_HTTPS_PROXY=http://user:pass@proxy-host:proxy-port
#FETCHER_NO_PROXY=localhost,127.0.0.1

# Optional: upload generated rate files to Cloudflare R2.
# Create an R2 API token with Object Read & Write permission for the bucket.
#R2_ENABLED=true
# Set false in production if R2 is the source of truth and local files should not be written.
#LOCAL_STORAGE_ENABLED=false
#R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
#R2_BUCKET=YOUR_BUCKET_NAME
#R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
#R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
# Optional prefix/folder inside the bucket, for example "uploads" or "wp-content/uploads".
# Leave blank to write rates/index.json and rates/*.json at the bucket root.
#R2_PREFIX=
#R2_CACHE_CONTROL=public, max-age=60
# Optional: R2 read timeout/cache tuning for web requests.
#R2_CONNECT_TIMEOUT=3
#R2_READ_TIMEOUT=8
#R2_MAX_ATTEMPTS=2
#R2_READ_CACHE_SECONDS=60
#PAGE_CACHE_SECONDS=60

# Optional: enable AI rewriting for game detail content
#OPENAI_API_KEY=YOUR_OPENAI_API_KEY
#OPENAI_MODEL=gpt-5.2
