# Copy to .env and edit as needed
# Optional: Docker Compose project/container prefix.
COMPOSE_PROJECT_NAME=exchangehub

# Path on host to WordPress uploads (will be mounted into container)
UPLOADS_HOST_PATH=./wp-content/uploads

# Your OpenExchangeRates App ID
#OPENEXCHANGE_APP_ID=YOUR_APP_ID

# Optional: rotate multiple OpenExchangeRates App IDs, comma-separated.
# At 5-minute intervals this uses about 8,640 requests/month total.
#OPENEXCHANGE_APP_IDS=APP_ID_1,APP_ID_2,APP_ID_3
# Optional: skip keys that are over quota or should not be used yet.
#OPENEXCHANGE_DISABLED_APP_IDS=APP_ID_1
# Optional: how long to pause an app id after quota/rate-limit/key errors. Default: 1 day.
#OXR_APP_ID_COOLDOWN_SECONDS=86400
# Optional: local monthly request guard per OpenExchangeRates app id.
# The fetcher counts successful OXR calls and skips an app id once it reaches limit * percent.
# Set reset days to match each app id's billing/quota reset day if they were created on different dates.
#OXR_APP_ID_MONTHLY_LIMIT=1000
#OXR_APP_ID_MAX_USAGE_PERCENT=115
#OXR_APP_ID_RESET_DAY=1
#OXR_APP_ID_RESET_DAYS=APP_ID_1:7,APP_ID_2:12,APP_ID_3:21

# Optional: route only the fetcher outbound API requests through a proxy/NAT.
# This hides the web server's direct outbound IP from the rate provider.
#FETCHER_HTTP_PROXY=http://user:pass@proxy-host:proxy-port
#FETCHER_HTTPS_PROXY=http://user:pass@proxy-host:proxy-port
#FETCHER_NO_PROXY=localhost,127.0.0.1

# Optional: upload generated rate files to Cloudflare R2.
# Create an R2 API token with Object Read & Write permission for the bucket.
#R2_ENABLED=true
# Set false in production if R2 is the source of truth and local files should not be written.
#LOCAL_STORAGE_ENABLED=false
#R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
#R2_BUCKET=YOUR_BUCKET_NAME
#R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
#R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
# Optional prefix/folder inside the bucket, for example "uploads" or "wp-content/uploads".
# Leave blank to write rates/index.json and rates/*.json at the bucket root.
#R2_PREFIX=
#R2_CACHE_CONTROL=public, max-age=60
# Optional: R2 read timeout/cache tuning for web requests.
#R2_CONNECT_TIMEOUT=3
#R2_READ_TIMEOUT=8
#R2_MAX_ATTEMPTS=2
#R2_READ_CACHE_SECONDS=60
#PAGE_CACHE_SECONDS=60

# Built-in Docker mailserver. Requires DNS MX/SPF/DKIM/DMARC and open mail ports on the VPS.
#MAIL_HOSTNAME=mail
#MAIL_DOMAIN=ratehubfx.com
#MAIL_PORT_SMTP=25
#MAIL_PORT_SUBMISSION=587
#MAIL_PORT_SUBMISSIONS=465
#MAIL_PORT_IMAP=143
#MAIL_PORT_IMAPS=993
#MAIL_SSL_TYPE=self-signed
#MAIL_POSTMASTER_ADDRESS=postmaster@ratehubfx.com
#MAIL_ENABLE_SPAMASSASSIN=1
#MAIL_ENABLE_CLAMAV=0
#MAIL_ENABLE_FAIL2BAN=1
#MAIL_ENABLE_POSTGREY=0
#MAIL_PERMIT_DOCKER=none
#MAIL_POSTFIX_INET_PROTOCOLS=ipv4
# Optional outbound SMTP relay for VPS providers that block outbound port 25.
# Use either MAIL_DEFAULT_RELAY_HOST, or MAIL_RELAY_HOST plus MAIL_RELAY_PORT.
#MAIL_DEFAULT_RELAY_HOST=[smtp-relay.example.com]:587
#MAIL_RELAY_HOST=smtp-relay.example.com
#MAIL_RELAY_PORT=587
#MAIL_RELAY_USER=YOUR_RELAY_USERNAME
#MAIL_RELAY_PASSWORD=YOUR_RELAY_PASSWORD
# Cloudflare DNS import script.
# Token needs Zone:DNS:Edit for this zone.
#CF_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN
#CF_ZONE_NAME=ratehubfx.com
#CF_ZONE_ID=
#MAIL_SERVER_IP=YOUR_VPS_IP
#MAIL_MX_PRIORITY=10
#MAIL_SPF=v=spf1 mx -all
#MAIL_DMARC=v=DMARC1; p=quarantine; rua=mailto:test.noreply909@gmail.com

# Contact form mail delivery. Uses the built-in mailserver by default in Docker Compose.
# Generate a stable secret for production sessions.
#FLASK_SECRET_KEY=GENERATE_A_LONG_RANDOM_SECRET
#SITE_CONTACT_EMAIL=contact@ratehubfx.com
#CONTACT_FORWARD_TO=test.noreply909@gmail.com
#CONTACT_FROM_EMAIL=contact@ratehubfx.com
#CONTACT_SMTP_HOST=mailserver
#CONTACT_SMTP_PORT=587
#CONTACT_SMTP_USER=contact@ratehubfx.com
#CONTACT_SMTP_PASSWORD=YOUR_SMTP_PASSWORD
#CONTACT_SMTP_USE_TLS=true
#CONTACT_SMTP_TLS_VERIFY=false
#CONTACT_RATE_LIMIT_SECONDS=60
#CONTACT_MIN_SUBMIT_SECONDS=3
#CONTACT_ROTATION_TOLERANCE=8

# Optional: enable AI rewriting for game detail content
#OPENAI_API_KEY=YOUR_OPENAI_API_KEY
#OPENAI_MODEL=gpt-5.2
